<!DOCTYPE html>
<html>
<head>
    <title>mailto: Link Testing Page</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body { 
            font-family: Arial, sans-serif; 
            padding: 20px; 
            line-height: 1.6;
        }
        .email-section { 
            margin: 20px 0; 
            padding: 15px; 
            border: 1px solid #ddd; 
            border-radius: 5px;
        }
        .email-link { 
            display: inline-block; 
            margin: 10px 0; 
            padding: 10px 15px; 
            background: #007bff; 
            color: white; 
            text-decoration: none; 
            border-radius: 5px;
        }
        .email-link:hover { 
            background: #0056b3; 
        }
        .code-block {
            background: #f8f9fa;
            padding: 10px;
            border-radius: 3px;
            font-family: monospace;
            margin: 5px 0;
        }
    </style>
</head>
<body>
    <h1>📧 mailto: Link Testing Page</h1>
    
    <!-- Basic mailto Links -->
    <div class="email-section">
        <h2>🔹 Basic mailto: Links</h2>
        <a href="mailto:test@example.com" class="email-link">
            📧 Simple Email
        </a>
        <div class="code-block">mailto:test@example.com</div>
        
        <a href="mailto:support@company.com" class="email-link">
            🛠️ Support Email
        </a>
        <div class="code-block">mailto:support@company.com</div>
    </div>
    
    <!-- mailto with Subject -->
    <div class="email-section">
        <h2>🔹 mailto: with Subject</h2>
        <a href="mailto:test@example.com?subject=Hello World" class="email-link">
            📧 Email with Subject
        </a>
        <div class="code-block">mailto:test@example.com?subject=Hello World</div>
        
        <a href="mailto:feedback@company.com?subject=App Feedback" class="email-link">
            💬 Feedback Email
        </a>
        <div class="code-block">mailto:feedback@company.com?subject=App Feedback</div>
    </div>
    
    <!-- mailto with Body -->
    <div class="email-section">
        <h2>🔹 mailto: with Body</h2>
        <a href="mailto:test@example.com?body=This is a test email body." class="email-link">
            📝 Email with Body
        </a>
        <div class="code-block">mailto:test@example.com?body=This is a test email body.</div>
        
        <a href="mailto:support@company.com?body=Please describe your issue here..." class="email-link">
            🔧 Support Request
        </a>
        <div class="code-block">mailto:support@company.com?body=Please describe your issue here...</div>
    </div>
    
    <!-- mailto with Subject and Body -->
    <div class="email-section">
        <h2>🔹 mailto: with Subject & Body</h2>
        <a href="mailto:test@example.com?subject=Test Subject&body=This is the email body content." class="email-link">
            📧 Complete Email
        </a>
        <div class="code-block">mailto:test@example.com?subject=Test Subject&body=This is the email body content.</div>
        
        <a href="mailto:contact@company.com?subject=Website Inquiry&body=Hi, I have a question about your services..." class="email-link">
            💼 Business Inquiry
        </a>
        <div class="code-block">mailto:contact@company.com?subject=Website Inquiry&body=Hi, I have a question about your services...</div>
    </div>
    
    <!-- mailto with CC -->
    <div class="email-section">
        <h2>🔹 mailto: with CC</h2>
        <a href="mailto:primary@example.com?cc=copy@example.com&subject=CC Test" class="email-link">
            📧 Email with CC
        </a>
        <div class="code-block">mailto:primary@example.com?cc=copy@example.com&subject=CC Test</div>
        
        <a href="mailto:team@company.com?cc=manager@company.com&cc=hr@company.com&subject=Team Meeting" class="email-link">
            👥 Team Email with Multiple CC
        </a>
        <div class="code-block">mailto:team@company.com?cc=manager@company.com&cc=hr@company.com&subject=Team Meeting</div>
    </div>
    
    <!-- mailto with BCC -->
    <div class="email-section">
        <h2>🔹 mailto: with BCC</h2>
        <a href="mailto:recipient@example.com?bcc=hidden@example.com&subject=BCC Test" class="email-link">
            🔒 Email with BCC
        </a>
        <div class="code-block">mailto:recipient@example.com?bcc=hidden@example.com&subject=BCC Test</div>
    </div>
    
    <!-- Complex mailto -->
    <div class="email-section">
        <h2>🔹 Complex mailto: Links</h2>
        <a href="mailto:primary@example.com?cc=copy@example.com&bcc=hidden@example.com&subject=Complex Email Test&body=This is a complex email with CC, BCC, subject, and body." class="email-link">
            🎯 All Parameters
        </a>
        <div class="code-block">mailto:primary@example.com?cc=copy@example.com&bcc=hidden@example.com&subject=Complex Email Test&body=This is a complex email with CC, BCC, subject, and body.</div>
        
        <a href="mailto:sales@company.com?cc=manager@company.com&subject=Product%20Inquiry&body=Hello%2C%0A%0AI%20am%20interested%20in%20your%20product.%0A%0APlease%20send%20me%20more%20information.%0A%0AThank%20you!" class="email-link">
            🛒 Sales Inquiry (URL Encoded)
        </a>
        <div class="code-block">mailto:sales@company.com?cc=manager@company.com&subject=Product%20Inquiry&body=Hello%2C%0A%0AI%20am%20interested%20in%20your%20product.%0A%0APlease%20send%20me%20more%20information.%0A%0AThank%20you!</div>
    </div>
    
    <!-- Multiple Recipients -->
    <div class="email-section">
        <h2>🔹 Multiple Recipients</h2>
        <a href="mailto:first@example.com,second@example.com?subject=Multiple Recipients" class="email-link">
            👥 Multiple To Recipients
        </a>
        <div class="code-block">mailto:first@example.com,second@example.com?subject=Multiple Recipients</div>
        
        <a href="mailto:team@company.com,support@company.com,info@company.com?subject=Company Wide Email" class="email-link">
            🏢 Company Wide Email
        </a>
        <div class="code-block">mailto:team@company.com,support@company.com,info@company.com?subject=Company Wide Email</div>
    </div>
    
    <!-- Interactive Testing -->
    <div class="email-section">
        <h2>🔹 Interactive mailto: Generator</h2>
        <div style="background: #f8f9fa; padding: 15px; border-radius: 5px;">
            <input type="email" id="emailTo" placeholder="To: email@example.com" style="width: 100%; margin: 5px 0; padding: 8px;">
            <input type="text" id="emailSubject" placeholder="Subject" style="width: 100%; margin: 5px 0; padding: 8px;">
            <textarea id="emailBody" placeholder="Email body" style="width: 100%; margin: 5px 0; padding: 8px; height: 80px;"></textarea>
            <button onclick="generateMailto()" style="padding: 10px 20px; background: #28a745; color: white; border: none; border-radius: 3px; cursor: pointer;">
                📧 Generate mailto: Link
            </button>
            <div id="generatedLink" style="margin-top: 15px;"></div>
        </div>
    </div>
    
    <!-- Special Characters Testing -->
    <div class="email-section">
        <h2>🔹 Special Characters & Encoding</h2>
        <a href="mailto:test@example.com?subject=Test with spaces&body=Line 1%0ALine 2%0ALine 3" class="email-link">
            📝 Multi-line Body
        </a>
        <div class="code-block">mailto:test@example.com?subject=Test with spaces&body=Line 1%0ALine 2%0ALine 3</div>
        
        <a href="mailto:info@company.com?subject=Special%20Characters%20%26%20Symbols&body=Testing%20%40%20%23%20%24%20%25%20%5E%20%26%20*%20symbols" class="email-link">
            🔣 Special Characters
        </a>
        <div class="code-block">mailto:info@company.com?subject=Special%20Characters%20%26%20Symbols&body=Testing%20%40%20%23%20%24%20%25%20%5E%20%26%20*%20symbols</div>
    </div>

    <script>
        function generateMailto() {
            const to = document.getElementById('emailTo').value;
            const subject = document.getElementById('emailSubject').value;
            const body = document.getElementById('emailBody').value;
            
            let mailto = 'mailto:' + encodeURIComponent(to);
            let params = [];
            
            if (subject) params.push('subject=' + encodeURIComponent(subject));
            if (body) params.push('body=' + encodeURIComponent(body));
            
            if (params.length > 0) {
                mailto += '?' + params.join('&');
            }
            
            document.getElementById('generatedLink').innerHTML = 
                `<strong>Generated Link:</strong><br>
                <div class="code-block">${mailto}</div>
                <a href="${mailto}" class="email-link">📧 Test This Link</a>`;
        }
        
        // Add click tracking
        document.querySelectorAll('a[href^="mailto:"]').forEach(link => {
            link.addEventListener('click', function(e) {
                console.log('mailto: clicked:', this.href);
            });
        });
    </script>
</body>
</html>
